VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Donkie AI — secret configurado no painel Supabase > Edge Functions > Secrets
# ANTHROPIC_API_KEY=

# Freshdesk — secrets para a Edge Function (configurar no painel Supabase > Edge Functions > Secrets)
# FRESHDESK_DOMAIN=donc
# FRESHDESK_API_KEY=

# Resend — e-mail transacional (configurar em Supabase Dashboard > Edge Functions > send-email > Secrets)
# RESEND_API_KEY=

# Freshdesk — script de mapeamento local (scripts/freshdesk-map-companies.js)
# SUPABASE_SERVICE_ROLE_KEY=
# FRESHDESK_DOMAIN=donc
# FRESHDESK_API_KEY=

# Supabase Management API — script fix-supabase-urls.js
# Gere o token em: https://supabase.com/dashboard/account/tokens
# Armazene apenas em .env.local (gitignorado). Nunca commitar.
# Modo de uso: node --env-file=.env.local scripts/fix-supabase-urls.js
# SUPABASE_ACCESS_TOKEN=sbp_
